pipeline {
    agent any

    tools {
        terraform 'terraform'
    }

    stages {
        stage('Terraform Infra') {
            steps {
                dir('Terraform') {
                    sh 'terraform init'
                    sh 'terraform apply -auto-approve'
                }
            }
        }

        stage('K8s Deployment') {
            steps {
                sh 'kubectl apply -f K8s/'
            }
        }
    }
}
