pipeline {
    agent any
 tools {
        terraform 'terraform'
    }
    
    environment {
        // Isse Jenkins ke "Manage Credentials" section mein match hona chahiye
        DOCKER_HUB_CREDS = credentials('docker-hub-creds')
    }

    stages {
        stage('Terraform Infra') {
            steps {
                dir('Terraform') {
                    sh 'terraform init'
                    sh 'terraform apply -auto-approve'
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                // Login using credentials
                sh "echo \$DOCKER_HUB_CREDS_PSW | docker login -u \$DOCKER_HUB_CREDS_USR --password-stdin"
                
                // Build and Push User Service
                sh "docker build -t \$DOCKER_HUB_CREDS_USR/user-service:latest ./user-service"
                sh "docker push \$DOCKER_HUB_CREDS_USR/user-service:latest"
                
                // Build and Push Auth Service
                sh "docker build -t \$DOCKER_HUB_CREDS_USR/auth-service:latest ./auth-service"
                sh "docker push \$DOCKER_HUB_CREDS_USR/auth-service:latest"
            }
        }

        stage('K8s Deployment') {
            steps {
                // Kubernetes manifests apply karna
                sh 'kubectl apply -f K8s/'
            }
        }
    }
    
    post {
        always {
            // Logout for security
            sh 'docker logout'
        }
    }
}