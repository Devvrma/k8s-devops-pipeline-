pipeline {
agent any
stages {

    stage('Terraform Infra') {
        steps {
            bat 'cd Terraform && terraform init'
            bat 'cd Terraform && terraform apply -auto-approve'
        }
    }

    stage('K8s Deployment') {
        steps {
            bat 'kubectl apply -f K8s\\'
        }
    }

    stage('Verify') {
        steps {
            bat 'kubectl get pods'
        }
    }
}
}
